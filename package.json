{
  "name": "town-scout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "dotenv -e .env.local -e .env -- prisma generate",
    "dev": "next dev",
    "build": "dotenv -e .env.local -e .env -- prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "seed:events": "dotenv -e .env.local -e .env -- tsx scripts/seed-flint-events.ts",
    "db:push": "dotenv -e .env.local -e .env -- prisma db push --skip-generate",
    "prisma:generate": "dotenv -e .env.local -e .env -- prisma generate",
    "db:sync": "npm run db:push && npm run prisma:generate",
    "db:migrate": "dotenv -e .env.local -e .env -- prisma migrate dev",
    "postinstall": "dotenv -e .env.local -e .env -- prisma generate"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "leaflet": "^1.9.4",
    "next": "16.1.7",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "prisma": "5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
